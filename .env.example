# Neon Postgres connection string used by Drizzle on the server.
DATABASE_URL=postgres://user:password@host/db?sslmode=require

# Optional: secret used to sign / validate auxiliary tokens. Generate with
#   openssl rand -base64 32
# This is NOT required for DB-backed sessions but must be set in production
# if you ever re-introduce JWTs.
AUTH_SECRET=replace-me-with-a-32-byte-random-string

# Cookie name for the session cookie (httpOnly, secure in production).
SESSION_COOKIE_NAME=session

# Public URL the app is served from. Used to build absolute links inside
# transactional email (password reset, etc.). Defaults to localhost in dev.
APP_URL=http://localhost:3000

# Resend API key used to dispatch transactional email
# (https://resend.com/api-keys). When unset, emails are logged to stdout
# instead of being sent — useful for local development.
RESEND_API_KEY=

# "From" address for outbound mail. Must be a verified sender on your
# Resend account in production.
EMAIL_FROM=no-reply@example.com

# Vercel Blob read-write token used by the admin product image-upload route.
# Provision via:  Vercel project → Storage → Blob → Connect → Read/Write token.
# When unset, the server falls back to deterministic placeholder URLs in dev
# and returns a 503 ("not configured") in production.
BLOB_READ_WRITE_TOKEN=
